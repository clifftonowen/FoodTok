<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/foodtok_cream"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="32dp">

    <!-- Upload icon placeholder -->
    <ImageView
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:layout_marginBottom="24dp"
        android:src="@drawable/ic_burger_foodtok"
        android:contentDescription="Upload recipe" />

    <!-- Title -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:text="Share Your Recipe"
        android:textAlignment="center"
        android:textColor="@color/foodtok_text_primary"
        android:textSize="22sp"
        android:textStyle="bold" />

    <!-- Subtitle -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="32dp"
        android:text="Upload a photo and share your\nrecipe with the world"
        android:textAlignment="center"
        android:textColor="@color/foodtok_text_secondary"
        android:textSize="15sp" />

    <!-- Upload button -->
    <Button
        android:id="@+id/btnUpload"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_button_primary"
        android:text="Upload Recipe"
        android:textColor="@color/foodtok_text_on_dark"
        android:textSize="16sp"
        android:textStyle="bold" />

</LinearLayout>