<resources>
    <style name="Theme.FoodTok" parent="Theme.MaterialComponents.Light.NoActionBar">
        <!-- Primary brand color (green) -->
        <item name="colorPrimary">@color/foodtok_green</item>
        <item name="colorPrimaryVariant">@color/foodtok_green_dark</item>
        <item name="colorOnPrimary">@color/foodtok_text_on_dark</item>

        <!-- Accent color (orange) -->
        <item name="colorSecondary">@color/foodtok_orange</item>
        <item name="colorSecondaryVariant">@color/foodtok_orange_dark</item>
        <item name="colorOnSecondary">@color/foodtok_text_on_dark</item>

        <!-- Background -->
        <item name="android:colorBackground">@color/foodtok_cream</item>
        <item name="colorSurface">@color/foodtok_white</item>
        <item name="colorOnSurface">@color/foodtok_text_primary</item>

        <!-- Error -->
        <item name="colorError">@color/foodtok_error</item>

        <!-- Status bar -->
        <item name="android:statusBarColor">@color/foodtok_green_dark</item>
    </style>
</resources>